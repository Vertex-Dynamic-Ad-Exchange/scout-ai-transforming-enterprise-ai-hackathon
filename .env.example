# Scout — env var manifest
#
# Each package owns its own src/config.ts and documents its vars here as it
# lands. Nothing in this repo auto-loads .env yet — pass these inline or
# `set -a; source .env; set +a` before invoking scripts.

# @scout/harness — browser-use Cloud session provisioning (PRP-B2).
# Server-side only; never reaches client/UI code.
# Get a key at https://cloud.browser-use.com → API Keys.
BROWSER_USE_API_KEY=
# Optional. Override only for staging; omit to use the SDK default (prod).
BROWSER_USE_BASE_URL=

# @scout/dashboard — Vite + React SPA (PRP clusterD/04).
# Every VITE_* var is shipped to the client bundle (vitejs.dev/guide/env-and-mode).
# CLAUDE.md § Working agreements: NO VITE_* may hold a secret. The
# bundle-grep test at packages/dashboard/src/__bundle__/no-secrets.test.ts
# pins this for the three secret env-var names in the system today.
# URL of the operator-run Lobster Trap dashboard the iframe sources.
# Foundation Q8 locks the iframe approach; do NOT thread advertiserId in.
VITE_LOBSTERTRAP_URL=http://localhost:8080/_lobstertrap/
# URL of @scout/dashboard-backend; consumed by Vite dev-proxy and by
# fetch() at runtime. Backend forwards reads to AuditStore.
VITE_DASHBOARD_BACKEND_URL=http://localhost:5174
# Session ID for the stub-auth allowlist (x-advertiser-id header). NOT
# a secret. Real auth lands in dashboard-auth.md follow-up.
VITE_DEMO_ADVERTISER_ID=demo-advertiser
