# Scout — env var manifest
#
# Each package owns its own src/config.ts and documents its vars here as it
# lands. Nothing in this repo auto-loads .env yet — pass these inline or
# `set -a; source .env; set +a` before invoking scripts.

# @scout/harness — browser-use Cloud session provisioning (PRP-B2).
# Server-side only; never reaches client/UI code.
# Get a key at https://cloud.browser-use.com → API Keys.
BROWSER_USE_API_KEY=
# Optional. Override only for staging; omit to use the SDK default (prod).
BROWSER_USE_BASE_URL=

GEMINI_API_KEY=

PORT=
HOST=